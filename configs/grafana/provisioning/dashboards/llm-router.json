    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Per-target-model request throughput, stacked — shows how the router distributes traffic across backends over time.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
