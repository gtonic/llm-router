# ============================================
# LLM Router - Environment Variables
# ============================================

# Application Settings
APP_NAME=llm-router
APP_DEBUG=false

# Routing Configuration
ROUTER_DEFAULT_STRATEGY=complexity
ROUTER_DEFAULT_MODEL=llama-local
ROUTER_FALLBACK_MODEL=gpt-5.4-nano
ROUTER_ADMIN_TOKEN=replace-with-a-long-random-token
ROUTER_STRICT_CONFIG=true
ROUTER_MAX_RETRIES=3
ROUTER_TIMEOUT=30

# Model Configuration (comma-separated list of model IDs)
ROUTER_ALLOWED_MODELS=llama-local,gpt-5.6-luna

# Fallback Strategy (last_resort | round_robin | random | none)
ROUTER_FALLBACK_STRATEGY=round_robin

# Cost Optimization Settings
ROUTER_COST_OPTIMIZATION=false
ROUTER_MAX_COST_PER_REQUEST=0.01
ROUTER_COST_THRESHOLD=0.005

# PII Detection Settings
PII_DETECTION_ENABLED=true
PII_DETECTION_SENSITIVITY=high

# Tracing / OpenTelemetry
OTEL_ENABLED=true
OTEL_SERVICE_NAME=llm-router
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_EXPORTER_OTLP_ENABLED=false

# Container / Docker Settings
# (for apple/container or Docker Desktop)
CONTAINER_PORT=8000
