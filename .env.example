# ═══════════════════════════════════════════════════════════
# LLM Router & Gateway — Example Configuration
# ═══════════════════════════════════════════════════════════
# Copy to .env and adjust values. All vars use ROUTER_ prefix.

# ── Core ─────────────────────────────────────────────────
ROUTER_DEFAULT_STRATEGY=policy
ROUTER_DEFAULT_MODEL=llama-local

# ── Model Backends ───────────────────────────────────────
# Profiles are loaded from the profiles/ directory as YAML files.
# See profiles/local.yaml and profiles/remote.yaml for examples.

# ── Routing ──────────────────────────────────────────────
# Policy files are loaded from the agent-policies/ directory.
# See agent-policies/default.yaml for examples.

# ── Guardrails ───────────────────────────────────────────
ROUTER_GUARDRAILS_INPUT=true
ROUTER_GUARDRAILS_OUTPUT=true
ROUTER_PII_REDACT=true
ROUTER_RATE_LIMIT_RPM=60
ROUTER_RATE_LIMIT_PPM=60000
ROUTER_ABUSE_BLOCK_THRESHOLD=0.8

# ── OpenTelemetry ────────────────────────────────────────
ROUTER_OTLP_ENABLED=true
ROUTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
ROUTER_OTLP_PROTOCOL=http/protobuf

# ── Logging ──────────────────────────────────────────────
ROUTER_LOG_DIR=logs
ROUTER_LOG_LEVEL=INFO

# ── Model Provider Keys (uncomment and set) ─────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# AZURE_OPENAI_API_KEY=...
