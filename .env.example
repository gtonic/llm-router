# ============================================
# LLM Router - Environment Variables
# ============================================
# Only ROUTER_-prefixed keys that map to a real GatewaySettings field (plus the
# per-model ${API_KEY} references) are read; anything else is ignored.

# ── Routing ────────────────────────────────
ROUTER_DEFAULT_STRATEGY=complexity   # policy | complexity | hybrid | round_robin | latency | cost
ROUTER_DEFAULT_MODEL=llama-local
ROUTER_FALLBACK_MODEL=gpt-4o-mini
ROUTER_STRICT_CONFIG=true            # fail fast on misconfiguration
ROUTER_PREWARM=true                  # warm local backends at startup

# ── Auth ───────────────────────────────────
# Comma-separated data-plane API keys (Authorization: Bearer <key> / X-API-Key).
# SECURE DEFAULT: with no keys the inference API is fail-closed (401). For a
# trusted/local network you can instead opt into open access:
ROUTER_API_KEYS=
ROUTER_ALLOW_ANONYMOUS=false   # set true to allow unauthenticated access (trusted networks only)
ROUTER_ADMIN_TOKEN=replace-with-a-long-random-token

# ── Resilience — per-backend circuit breaker ──
ROUTER_CIRCUIT_BREAKER_ENABLED=true
ROUTER_CIRCUIT_BREAKER_THRESHOLD=5
ROUTER_CIRCUIT_BREAKER_COOLDOWN=30

# ── Session affinity ───────────────────────
# Stick a conversation to the backend that first served it (session key:
# X-Session-Id header, else user_id). Opt-in.
ROUTER_SESSION_AFFINITY_ENABLED=false
ROUTER_SESSION_AFFINITY_TTL=1800

# ── Rate limits (explicit env wins over config/runtime.yaml) ──
ROUTER_RATE_LIMIT_RPM=60
ROUTER_RATE_LIMIT_TPM=60000

# ── Request caps (DoS/cost guards) ─────────
ROUTER_MAX_OUTPUT_TOKENS=131072
ROUTER_MAX_MESSAGES=1000
ROUTER_MAX_TOTAL_PROMPT_CHARS=4000000

# ── Observability — OpenTelemetry tracing ──
# NOTE the field name is OTLP (not OTELP). For docker-compose, host is 'jaeger'.
ROUTER_OTLP_ENABLED=true
ROUTER_OTLP_ENDPOINT=http://jaeger:4318/v1/traces
ROUTER_OTLP_PROTOCOL=http/protobuf

# ── Logging ────────────────────────────────
ROUTER_LOG_LEVEL=INFO

# ── Provider credentials (referenced as ${OPENAI_API_KEY} in profiles/*.yaml) ──
OPENAI_API_KEY=sk-...

# ── Container ──────────────────────────────
CONTAINER_PORT=8000
